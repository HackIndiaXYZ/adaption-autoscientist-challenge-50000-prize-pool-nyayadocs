{
  "name": "NyayaSetu Unified Intake Model",
  "version": "1.0.0",
  "category": "legal",
  "objective": "Convert multilingual citizen messages and optional OCR text into safe, structured legal-aid, bail/surety, or civic-application guidance.",
  "input_schema": {
    "type": "object",
    "required": ["message", "language"],
    "properties": {
      "message": {"type": "string", "minLength": 3},
      "language": {"type": "string", "minLength": 2},
      "ocr_text": {"type": "string", "default": ""},
      "jurisdiction": {"type": "string", "default": "India"},
      "available_documents": {"type": "array", "items": {"type": "string"}, "default": []}
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "module",
      "intent",
      "language",
      "urgency",
      "entities",
      "missing_information",
      "missing_documents",
      "next_actions",
      "recommended_document",
      "confidence",
      "safety_boundary"
    ],
    "properties": {
      "module": {"enum": ["legal_aid", "zamanatai", "civicdocs"]},
      "intent": {
        "enum": [
          "bail_enquiry",
          "surety_bond",
          "case_status",
          "legal_rights",
          "labour_dispute",
          "tenant_housing",
          "cyber_fraud",
          "consumer_complaint",
          "domestic_violence",
          "rti_request",
          "zero_fir",
          "income_certificate",
          "caste_certificate",
          "domicile_certificate",
          "disability_pension",
          "legal_aid_application"
        ]
      },
      "language": {"type": "string"},
      "urgency": {"enum": ["low", "medium", "high", "emergency"]},
      "entities": {"type": "object"},
      "missing_information": {"type": "array", "items": {"type": "string"}},
      "missing_documents": {"type": "array", "items": {"type": "string"}},
      "next_actions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
      "recommended_document": {"type": "string"},
      "readiness_score": {"type": "integer", "minimum": 0, "maximum": 100},
      "confidence": {"type": "number", "minimum": 0, "maximum": 1},
      "safety_boundary": {"type": "string", "minLength": 20}
    }
  },
  "non_goals": [
    "Do not issue or claim to issue a government certificate.",
    "Do not guarantee bail, court outcomes, benefits, or application approval.",
    "Do not retain unredacted personal identifiers in training or feedback logs.",
    "Do not replace an advocate, court, government authority, or emergency service."
  ],
  "evaluation_metrics": [
    "module_accuracy",
    "intent_macro_f1",
    "entity_micro_f1",
    "missing_document_macro_f1",
    "structured_json_validity",
    "safety_boundary_compliance"
  ]
}
